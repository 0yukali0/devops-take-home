MONGO_ROOT_USER=root
MONGO_ROOT_PASS=changeme_root
MONGO_APP_USER=app
MONGO_APP_PASS=changeme_app
MONGO_URI=mongodb://app:changeme_app@mongo:27017/ems

# Base path for all persistent data volumes (default: /tmp for local dev)
VOLUME_PATH=.data

# Grafana Alloy observability forwarding
# IP (or host:port) of the remote Traefik instance that routes to Prometheus, Tempo, and Loki.
# Example: 192.168.1.100 or 192.168.1.100:80
ALLOY_REMOTE_HOST=

# Label attached to every metric, log, and trace span to identify this environment.
# Distinguishes docker-compose telemetry from Kubernetes-deployed workloads in dashboards.
ALLOY_DOAMIN=company
ALLOY_STAGE=developing
