{
  "name": "ems-edge-simulator",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "esbuild src/instrumentation.ts src/index.ts src/collector.ts src/seed.ts --bundle --platform=node --outdir=dist --format=cjs --sourcemap",
    "start": "node --require ./dist/instrumentation.js dist/index.js",
    "dev": "tsx --require ./src/instrumentation.ts watch src/index.ts | pino-pretty -c -C -L debug",
    "dev:collector": "tsx --require ./src/instrumentation.ts watch src/collector.ts | pino-pretty -c -C -L debug",
    "seed": "tsx src/seed.ts",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.8",
    "@next/env": "^15.1.6",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.76.0",
    "@opentelemetry/exporter-trace-otlp-grpc": "^0.218.0",
    "@opentelemetry/sdk-node": "^0.218.0",
    "hono": "^4.6.20",
    "mongodb": "^6.10.0",
    "pg": "^8.13.0",
    "pino": "^9.5.0",
    "redis": "^4.7.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/pg": "^8.11.10",
    "esbuild": "^0.24.2",
    "pino-pretty": "^13.0.0",
    "tsx": "^4.7.1",
    "typescript": "^5.8.2"
  },
  "packageManager": "pnpm@9.15.4"
}
